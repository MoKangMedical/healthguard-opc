# HealthGuard OPC 环境变量配置

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/healthguard_opc

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置
# 请使用强密钥，建议使用: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# 邮件配置（用于提醒功能）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# 飞书集成配置
# 1. 访问 https://open.feishu.cn/ 创建应用
# 2. 获取 App ID 和 App Secret
# 3. 配置机器人能力并开启相关权限
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_DOMAIN=feishu  # feishu 或 lark
FEISHU_CONNECTION_MODE=websocket
FEISHU_ALLOWED_USERS=  # 允许使用的用户 ID，逗号分隔
FEISHU_HOME_CHANNEL=   # 默认通知频道 ID

# 健康数据阈值
BLOOD_PRESSURE_HIGH=140
BLOOD_PRESSURE_LOW=90
BLOOD_SUGAR_HIGH=7.0
BLOOD_SUGAR_LOW=3.9
HEART_RATE_HIGH=100
HEART_RATE_LOW=60

# 应用配置
DEBUG=true
LOG_LEVEL=info

# 前端配置
REACT_APP_API_URL=http://localhost:8000/api